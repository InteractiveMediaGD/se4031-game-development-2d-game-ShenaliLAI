# Unity Standard GitIgnore
# See: https://github.com/github/gitignore/blob/main/Unity.gitignore

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/

# Memory Captures
MemoryCaptures/

# Asset Checksum
Assets/*.asset.metadata

# Autogenerated JetBrains Rider project files
.idea/
*.sln
*.csproj
*.unityproj

# OS X
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a project folder
/.vs/
/GeneratedUI/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Unity WebGL
[Aa]ssets/[Ww]ebGLTemplates/*/
